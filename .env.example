# ─────────────────────────────────────────────────────────────
# EmailJS Konfiguration
# ─────────────────────────────────────────────────────────────
# 1. Kostenlosen Account anlegen: https://www.emailjs.com/
#
# 2. Email-Service anlegen (Gmail, Outlook, SMTP …):
#    Dashboard → Email Services → Add New Service
#    → Service ID kopieren
#
# 3. Zwei E-Mail-Templates anlegen:
#    Dashboard → Email Templates → Create New Template
#
#    Template A – Mitglieds-Bestätigung (VITE_EMAILJS_TEMPLATE_MEMBER)
#    Verfügbare Variablen im Template: {{to_name}}, {{vorname}}, {{nachname}},
#    {{adresse}}, {{beitrag}}, {{zusatz_spende}}, {{zahlungsart}},
#    {{iban_masked}}, {{kreditinstitut}}, {{datum}}
#    "To Email": {{to_email}}
#
#    Template B – Verein-Benachrichtigung (VITE_EMAILJS_TEMPLATE_VEREIN)
#    Verfügbare Variablen: {{vorname}}, {{nachname}}, {{adresse}},
#    {{email_mitglied}}, {{telefon}}, {{beitrag}}, {{zusatz_spende}},
#    {{zahlungsart}}, {{kontoinhaber}}, {{iban_voll}}, {{bic}},
#    {{kreditinstitut}}, {{datum}}
#    "To Email": {{to_email}}  (= grundschuleludweiler@schule.saarland)
#
# 4. Public Key kopieren:
#    Dashboard → Account → API Keys → Public Key
# ─────────────────────────────────────────────────────────────

VITE_EMAILJS_PUBLIC_KEY=DEIN_PUBLIC_KEY_HIER
VITE_EMAILJS_SERVICE_ID=DEIN_SERVICE_ID_HIER
VITE_EMAILJS_TEMPLATE_MEMBER=TEMPLATE_ID_MITGLIED_HIER
VITE_EMAILJS_TEMPLATE_VEREIN=TEMPLATE_ID_VEREIN_HIER
VITE_EMAILJS_TEMPLATE_KONTAKT=TEMPLATE_ID_KONTAKTFORMULAR_HIER
